# Streamlit Community Cloud secrets template.
#
# Copy this file's *contents* into your app's secrets in the Streamlit Cloud
# dashboard (App settings → Secrets). Every key here ends up as a process
# environment variable at runtime.

# --- AWS (boto3 default chain reads these standard names) -------------------
AWS_ACCESS_KEY_ID = "AKIA..."
AWS_SECRET_ACCESS_KEY = "..."
AWS_REGION = "us-east-1"
# Optional if using temporary creds:
# AWS_SESSION_TOKEN = "..."

# --- CanAID single-process / Streamlit Cloud mode ---------------------------
# Empty string = embedded mode (no FastAPI sidecar); FAISS replaces pgvector.
CANAID_API_URL = ""
CANAID_USE_FAISS = "true"
CANAID_EMBEDDED = "true"

# Disable cache backend probing on cold start; the in-memory fallback is used.
CANAID_CACHE_ENABLED = "true"

# --- Bedrock model overrides (optional — defaults are sane) -----------------
# CANAID_SUPERVISOR_MODEL = "us.anthropic.claude-sonnet-4-5-20250929-v1:0"
# CANAID_INTENT_MODEL     = "us.anthropic.claude-haiku-4-5-20251001-v1:0"
# CANAID_TOOL_MODEL       = "meta.llama3-3-70b-instruct-v1:0"
# CANAID_SUMMARIZER_MODEL = "us.amazon.nova-lite-v1:0"
# CANAID_EMBED_MODEL      = "amazon.titan-embed-text-v2:0"

# --- Bedrock Guardrails (optional) ------------------------------------------
# CANAID_GUARDRAIL_ID      = "abcd1234..."
# CANAID_GUARDRAIL_VERSION = "DRAFT"

# --- LangFuse Cloud (optional but recommended for the demo) -----------------
# LANGFUSE_HOST        = "https://us.cloud.langfuse.com"
# LANGFUSE_PUBLIC_KEY  = "pk-lf-..."
# LANGFUSE_SECRET_KEY  = "sk-lf-..."

# --- Logging ----------------------------------------------------------------
CANAID_LOG_LEVEL = "INFO"
